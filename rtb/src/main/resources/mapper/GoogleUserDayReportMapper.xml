<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.leeyom.scaffold.mapper.GoogleUserDayReportMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.leeyom.scaffold.domain.entity.GoogleUserDayReport">
        <id column="day" property="day" />
        <id column="guid_total" property="guidTotal" />
        <id column="today_guid_total" property="todayGuidTotal" />
        <id column="day_increase" property="dayIncrease" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        day,
        guid_total,
        today_guid_total,
        day_increase
    </sql>

    <insert id="batchInsert" parameterType="java.util.List">
        insert ignore google_user_day_report ( <include refid="Base_Column_List"/>) values
        <foreach collection="list" item="item" separator=",">
            (
            #{item.day} ,
            #{item.guidTotal} ,
            #{item.todayGuidTotal} ,
            #{item.dayIncrease} 
            )
        </foreach>
    </insert>
</mapper>
